20px; text-align: center; margin-bottom: 25px;\">Seu cadastro foi criado com sucesso!</h2>\n                \n                <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                    Olá <strong>{{ first_name }}</strong>,\n                </p>\n                \n                <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                    Seja bem-vindo(a) ao <strong>Gris</strong>, o sistema interno {{ prep_do }} {{ uel_type }} {{ uel_name }}!\n                </p>\n\n                <!-- DISCLAIMER / ALERTA -->\n                <div style=\"background-color: #fff3cd; border: 1px solid #ffeeba; border-radius: 6px; padding: 15px; margin: 25px 0; color: #856404; font-size: 14px; line-height: 1.5;\">\n                    <strong>Importante:</strong> O cadastro no Gris não substitui o registro escoteiro oficial. Ele serve apenas para acesso ao sistema interno {{ prep_do }} {{ uel_type }}.\n                </div>\n                \n                <!-- CARD DE CREDENCIAIS -->\n                <div style=\"background-color: #f8f9fa; border: 1px solid #e2e8f0; border-radius: 8px; padding: 25px; margin: 30px 0;\">\n                    <h3 style=\"margin-top: 0; color: #0d4d91; font-size: 15px; margin-bottom: 15px; text-transform: uppercase;\">Suas credenciais para acesso:</h3>\n                    \n                    <p style=\"margin: 5px 0; color: #1e293b; font-size: 14px;\">\n                        <strong>Usuário (E-mail):</strong> {{ user }}\n                    </p>\n                    \n                    <p style=\"margin-top: 15px; margin-bottom: 0; font-size: 13px; color: #64748b; font-style: italic;\">\n                        ⚠️ Você definirá sua senha pessoal ao clicar no botão abaixo.\n                    </p>\n                </div>\n                \n                <p style=\"color: #1e293b; font-size: 16px; font-weight: 500; text-align: center; margin-bottom: 25px;\">\n                    Para completar seu registro e acessar o sistema:\n                </p>\n                \n                 <!-- BOTÃO DE AÇÃO -->\n                <div style=\"text-align: center; margin-bottom: 30px;\">\n                    <a href=\"{{ link }}\" style=\"background-color: #0d4d91; color: white; padding: 14px 32px; text-decoration: none; border-radius: 6px; display: inline-block; font-weight: 600; font-size: 16px; box-shadow: 0 2px 4px rgba(13, 77, 145, 0.2);\">\n                        Completar Registro Agora\n                    </a>\n                </div>\n                \n                <div style=\"text-align: center; border-top: 1px solid #f1f5f9; padding-top: 20px; margin-top: 30px;\">\n                    <p style=\"color: #94a3b8; font-size: 13px; margin: 0;\">\n                        Se o botão acima não funcionar, acesse: <br>\n                        <a href=\"{{ link }}\" style=\"color: #0d4d91; word-break: break-all;\">{{ link }}</a>\n                    </p>\n                </div>\n            </div>\n            \n            <!-- FOOTER -->\n            <div style=\"background-color: #f1f5f9; padding: 15px 20px; text-align: center; border-top: 1px solid #e2e8f0; color: #64748b; font-size: 12px; line-height: 1.5;\">\n                Este alerta foi enviado automaticamente {{ prep_pelo }} {{ uel_type }} {{ uel_name }} via Portal Gris.\n            </div>\n        </div>\n    </div>\n\n",
  "response_html": "<!DOCTYPE html>\n<html>\n\n<body style=\"margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa;\">\n    \n    <!-- LÓGICA DE DADOS e GÊNERO GRAMATICAL -->\n    {% set uel = frappe.get_doc(\"Definicao da UEL\") %}\n    {% set uel_name = uel.nome_da_uel or \"Sua UEL\" %}\n    {% set uel_type = uel.tipo_uel or \"Unidade\" %}\n    \n    <!-- Define variáveis de artigo baseadas no tipo -->\n    {% set is_male = uel_type == \"Grupo Escoteiro\" %}\n    {% set prep_do = 'do' if is_male else 'da' %}\n    {% set prep_no = 'no' if is_male else 'na' %}\n    {% set prep_pelo = 'pelo' if is_male else 'pela' %}\n    \n        \n    <!-- Container Principal -->\n    <div style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.08);\">\n        \n        <!-- HEADER (Azul Gris) -->\n        <div style=\"background-color: #0d4d91; color: white; padding: 30px 30px; text-align: center;\">\n             <h1 style=\"margin: 0; font-size: 24px; font-weight: 600;\">🎉 Bem-vindo(a)!</h1>\n        </div>\n        \n        <!-- CONTEÚDO -->\n        <div style=\"padding: 40px 30px;\">\n            \n            <!-- LOGO (Fundo Branco) -->\n            <div style=\"text-align: center; margin-bottom: 25px;\">\n                {% if frappe.db.get_value(\"Website Settings\", \"Website Settings\", \"app_logo\") %}\n                    <img src=\"{{ site_url }}{{ frappe.db.get_value(\"Website Settings\", \"Website Settings\", \"app_logo\") }}\" alt=\"{{ uel_name }}\" style=\"max-height: 70px; width: auto; display: inline-block;\">\n                {% else %}\n                     <h2 style=\"color: #0d4d91; margin: 0; text-transform: uppercase; font-size: 18px;\">{{ uel_name }}</h2>\n                {% endif %}\n            </div>\n\n            <h2 style=\"margin-top: 0; color: #1e293b; font-size: 20px; text-align: center; margin-bottom: 25px;\">Seu cadastro foi criado com sucesso!</h2>\n            \n            <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                Olá <strong>{{ first_name }}</strong>,\n            </p>\n            \n            <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                Seja bem-vindo(a) ao <strong>Gris</strong>, o sistema interno {{ prep_do }} {{ uel_type }} {{ uel_name }}!\n            </p>\n\n            <!-- DISCLAIMER / ALERTA -->\n            <div style=\"background-color: #fff3cd; border: 1px solid #ffeeba; border-radius: 6px; padding: 15px; margin: 25px 0; color: #856404; font-size: 14px; line-height: 1.5;\">\n                <strong>Importante:</strong> O cadastro no Gris não substitui o registro escoteiro oficial. Ele serve apenas para acesso ao sistema interno {{ prep_do }} {{ uel_type }}.\n            </div>\n            \n            <!-- CARD DE CREDENCIAIS -->\n            <div style=\"background-color: #f8f9fa; border: 1px solid #e2e8f0; border-radius: 8px; padding: 25px; margin: 30px 0;\">\n                <h3 style=\"margin-top: 0; color: #0d4d91; font-size: 15px; margin-bottom: 15px; text-transform: uppercase;\">Suas credenciais para acesso:</h3>\n                \n                <p style=\"margin: 5px 0; color: #1e293b; font-size: 14px;\">\n                    <strong>Usuário (E-mail):</strong> {{ user }}\n                </p>\n                \n                <p style=\"margin-top: 15px; margin-bottom: 0; font-size: 13px; color: #64748b; font-style: italic;\">\n                    ⚠️ Você definirá sua senha pessoal ao clicar no botão abaixo.\n                </p>\n            </div>\n            \n            <p style=\"color: #1e293b; font-size: 16px; font-weight: 500; text-align: center; margin-bottom: 25px;\">\n                Para completar seu registro e acessar o sistema:\n            </p>\n            \n             <!-- BOTÃO DE AÇÃO -->\n            <div style=\"text-align: center; margin-bottom: 30px;\">\n                <a href=\"{{ link }}\" style=\"background-color: #0d4d91; color: white; padding: 14px 32px; text-decoration: none; border-radius: 6px; display: inline-block; font-weight: 600; font-size: 16px; box-shadow: 0 2px 4px rgba(13, 77, 145, 0.2);\">\n                    Completar Registro Agora\n                </a>\n            </div>\n            \n            <div style=\"text-align: center; border-top: 1px solid #f1f5f9; padding-top: 20px; margin-top: 30px;\">\n                <p style=\"color: #94a3b8; font-size: 13px; margin: 0;\">\n                    Se o botão acima não funcionar, acesse: <br>\n                    <a href=\"{{ link }}\" style=\"color: #0d4d91; word-break: break-all;\">{{ link }}</a>\n                </p>\n            </div>\n        </div>\n        \n        <!-- FOOTER -->\n        <div style=\"background-color: #f1f5f9; padding: 15px 20px; text-align: center; border-top: 1px solid #e2e8f0; color: #64748b; font-size: 12px; line-height: 1.5;\">\n            Este alerta foi enviado automaticamente {{ prep_pelo }} {{ uel_type }} {{ uel_name }} via Portal Gris.\n        </div>\n    </div>\n</body>\n</html>",
