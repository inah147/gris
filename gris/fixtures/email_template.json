  "response": "<meta charset=\"utf-8\">\n<title>Manifestação de Interesse Recebida</title>\n\n<!-- LÓGICA DE DADOS -->\n{% set uel = frappe.get_doc(\"Definicao da UEL\") %}\n{% set uel_name = uel.nome_da_uel or \"Sua UEL\" %}\n{% set uel_type = uel.tipo_uel or \"Unidade\" %}\n{% set whatsapp = uel.telefone %}\n{% set dia = uel.dia_de_atividade or \"Sábado\" %}\n{% set inicio = uel['horário_de_início'] %}\n{% set termino = uel['horário_de_término'] %}\n\n<!-- LOGICA JOVENS -->\n{% set siblings = frappe.get_all(\"Resposta Manifestacao de Interesse\", filters={\"email_do_responsavel\": doc.email_do_responsavel}, fields=[\"nome_do_jovem\"]) %}\n{% set names = [] %}\n{% for s in siblings %}\n    {% if s.nome_do_jovem not in names %}\n        {% set _ = names.append(s.nome_do_jovem) %}\n    {% endif %}\n{% endfor %}\n{% if not names %}\n    {% if doc.nome_do_jovem %}\n        {% set _ = names.append(doc.nome_do_jovem) %}\n    {% endif %}\n{% endif %}\n\n<!-- LOGICA GENEROS -->\n{% set is_male = uel_type == \"Grupo Escoteiro\" %}\n{% set prep_do = 'do' if is_male else 'da' %}\n{% set prep_no = 'no' if is_male else 'na' %}\n{% set prep_pelo = 'pelo' if is_male else 'pela' %}\n{% set prep_a = 'ao' if is_male else 'à' %}\n{% set is_sabado_domingo = dia in [\"Sábado\", \"Domingo\"] %}\n{% set art_dia = 'Todos os' if is_sabado_domingo else 'Todas as' %}\n\n<!-- Wrapper Cinza -->\n<div style=\"background-color: #f8f9fa; padding: 40px 20px;\">\n    \n    <!-- Container Principal -->\n    <div style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.08);\">\n        \n        <!-- HEADER -->\n        <div style=\"background-color: #0d4d91; color: white; padding: 30px 30px; text-align: center;\">\n             <h1 style=\"margin: 0; font-size: 24px; font-weight: 600;\">Bem-vindo(a) {{ prep_a }} {{ uel_type }}!</h1>\n        </div>\n        \n        <!-- CONTEÚDO -->\n        <div style=\"padding: 40px 30px;\">\n            <h2 style=\"margin-top: 0; color: #1e293b; font-size: 20px; text-align: center; margin-bottom: 25px;\">Ficamos muito felizes com seu interesse!</h2>\n            \n            <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                Olá <strong>{{ doc.nome_do_responsavel or 'Responsável' }}</strong>,\n            </p>\n            \n            <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                Você está recebendo este e-mail porque preencheu a manifestação de interesse para {{ 'os jovens' if names|length &gt; 1 else 'o(a) jovem' }}:\n            </p>\n\n            <ul style=\"color: #64748b; font-size: 16px; line-height: 1.6; padding-left: 20px; margin-top: 5px; margin-bottom: 20px;\">\n                {% for name in names %}\n                    <li><strong>{{ name }}</strong></li>\n                {% endfor %}\n            </ul>\n\n            <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                Em breve, você receberá um <strong>segundo e-mail</strong> neste mesmo endereço para cadastrar sua senha de acesso ao <strong>Gris</strong>.\n            </p>\n\n            <!-- CARD O QUE É O GRIS -->\n            <div style=\"background-color: #f0f9ff; padding: 20px; margin: 30px 0; border-radius: 6px;\">\n                <h3 style=\"margin-top: 0; color: #0c4a6e; font-size: 16px;\">O que é o Gris?</h3>\n                <p style=\"color: #334155; font-size: 14px; line-height: 1.5; margin-bottom: 15px;\">\n                    O Gris é o sistema interno de gestão {{ prep_do }} {{ uel_type }} {{ uel_name }}. Através dele, você poderá acompanhar cada etapa do processo de entrada.\n                </p>\n                <p style=\"color: #334155; font-size: 14px; line-height: 1.5; margin: 0;\">\n                    Algumas etapas do processo de recepção (como agendamento de visitas e envio de documentos) serão feitas diretamente pelo sistema.\n                </p>\n            </div>\n\n            <!-- ALERTA REGISTRO -->\n            <div style=\"background-color: #fff3cd; border: 1px solid #ffeeba; border-radius: 6px; padding: 15px; margin: 25px 0; color: #856404; font-size: 14px; line-height: 1.5;\">\n                <strong>Importante:</strong> O cadastro no Gris <span style=\"text-decoration: underline;\">não é o registro escoteiro oficial</span>. Ele é apenas nosso sistema de gestão interna para organizar a recepção.\n            </div>\n            \n            <!-- DIAGRAMA DE FLUXO -->\n            <h3 style=\"color: #1e293b; font-size: 18px; margin-top: 40px; text-align: center;\">Fluxo de Recepção</h3>\n            \n            <table style=\"width: 100%; table-layout: fixed; border-spacing: 0; margin-top: 20px;\">\n                <tbody>\n                    <tr>\n                        <!-- STEP 1: Manifestação de Interesse (Concluído) -->\n                        <td style=\"text-align: center; vertical-align: top; position: relative; padding: 0;\">\n                            <!-- Line Right (Green) -->\n                            <div style=\"position: absolute; top: 15px; left: 50%; width: 50%; height: 3px; background-color: #22c55e; z-index: 1;\"></div>\n                            \n                            <!-- Icon -->\n                            <div style=\"width: 30px; height: 30px; background-color: #22c55e; border-radius: 50%; margin: 0 auto; line-height: 30px; color: white; font-weight: bold; position: relative; z-index: 2;\">1</div>\n                            \n                            <!-- Text -->\n                            <div style=\"font-size: 12px; color: #0f172a; margin-top: 8px; font-weight: 600;\">Manifestação de Interesse</div>\n                        </td>\n                        \n                        <!-- STEP 2: Agendamento de Visita (Ativo) -->\n                        <td style=\"text-align: center; vertical-align: top; position: relative; padding: 0;\">\n                            <!-- Line Left (Green - Connection from 1) -->\n                            <div style=\"position: absolute; top: 15px; left: 0; width: 50%; height: 3px; background-color: #22c55e; z-index: 1;\"></div>\n                            <!-- Line Right (Gray - Path to 3) -->\n                            <div style=\"position: absolute; top: 15px; left: 50%; width: 50%; height: 3px; background-color: #e2e8f0; z-index: 1;\"></div>\n                            \n                            <!-- Icon -->\n                            <div style=\"width: 30px; height: 30px; background-color: #007bff; border-radius: 50%; margin: 0 auto; line-height: 30px; color: white; font-weight: bold; position: relative; z-index: 2;\">2</div>\n                            \n                            <!-- Text -->\n                            <div style=\"font-size: 12px; color: #007bff; margin-top: 8px; font-weight: 600;\">Agendamento de Visita</div>\n                        </td>\n                        \n                        <!-- STEP 3: Visita ao Grupo -->\n                        <td style=\"text-align: center; vertical-align: top; position: relative; padding: 0;\">\n                            <!-- Line Left (Gray) -->\n                            <div style=\"position: absolute; top: 15px; left: 0; width: 50%; height: 3px; background-color: #e2e8f0; z-index: 1;\"></div>\n                            <!-- Line Right (Gray) -->\n                            <div style=\"position: absolute; top: 15px; left: 50%; width: 50%; height: 3px; background-color: #e2e8f0; z-index: 1;\"></div>\n                            \n                            <!-- Icon -->\n                            <div style=\"width: 30px; height: 30px; background-color: #f1f5f9; border: 2px solid #e2e8f0; box-sizing: border-box; border-radius: 50%; margin: 0 auto; line-height: 26px; color: #94a3b8; font-weight: 600; position: relative; z-index: 2;\">3</div>\n                            \n                            <!-- Text -->\n                            <div style=\"font-size: 12px; color: #94a3b8; margin-top: 8px;\">Visita ao Grupo</div>\n                        </td>\n                        \n                        <!-- STEP 4: Acompanhamento e Integração -->\n                        <td style=\"text-align: center; vertical-align: top; position: relative; padding: 0;\">\n                            <!-- Line Left (Gray) -->\n                            <div style=\"position: absolute; top: 15px; left: 0; width: 50%; height: 3px; background-color: #e2e8f0; z-index: 1;\"></div>\n                            \n                            <!-- Icon -->\n                            <div style=\"width: 30px; height: 30px; background-color: #f1f5f9; border: 2px solid #e2e8f0; box-sizing: border-box; border-radius: 50%; margin: 0 auto; line-height: 26px; color: #94a3b8; font-weight: 600; position: relative; z-index: 2;\">4</div>\n                            \n                            <!-- Text -->\n                            <div style=\"font-size: 12px; color: #94a3b8; margin-top: 8px;\">Acompanhamento e Integração</div>\n                        </td>\n                    </tr>\n                </tbody>\n            </table>\n\n            <!-- INFO ATIVIDADES -->\n            <div style=\"margin-top: 40px; text-align: center;\">\n                <h3 style=\"color: #1e293b; font-size: 16px; margin-bottom: 10px;\">Horário das Atividades</h3>\n                <p style=\"color: #64748b; font-size: 15px; margin: 0;\">\n                    {{ art_dia }} <strong>{{ dia }}s</strong><br>\n                    das {{ inicio or '---' }} às {{ termino or '---' }}\n                </p>\n            </div>\n            \n            <!-- CONTATO -->\n            <div style=\"margin-top: 40px; border-top: 1px solid #e2e8f0; padding-top: 30px;\">\n                <p style=\"color: #64748b; font-size: 14px; line-height: 1.6; text-align: center;\">\n                    Vamos entrar em contato pelo telefone <strong>{{ doc.celular_do_responsavel }}</strong> para agendar os próximos passos.\n                </p>\n                <p style=\"color: #64748b; font-size: 14px; line-height: 1.6; text-align: center;\">Ficou com dúvida? Fale com a gente:</p>\n            </div>\n            \n            <!-- BOTÃO WHATSAPP -->\n            {% if whatsapp %}\n            <div style=\"text-align: center; margin-top: 20px; margin-bottom: 30px;\">\n                <a href=\"https://wa.me/{{ whatsapp | replace(' ', '') | replace('-', '') | replace('(', '') | replace(')', '') }}\" style=\"background-color: #25D366; color: white; padding: 12px 28px; text-decoration: none; border-radius: 50px; display: inline-block; font-weight: 600; font-size: 15px; box-shadow: 0 4px 6px -1px rgba(37, 211, 102, 0.3);\">\n                    Entre em contato por WhatsApp\n                </a>\n            </div>\n            {% endif %}\n\n        </div>\n        \n        <!-- FOOTER -->\n        <div style=\"background-color: #f1f5f9; padding: 20px 20px; text-align: center; border-top: 1px solid #e2e8f0; color: #94a3b8; font-size: 12px; line-height: 1.5;\">\n            Enviado com amor ❤️ {{ prep_pelo }} {{ uel_type }} {{ uel_name }}<br>\n            Este é um e-mail automático, por favor não responda.\n        </div>\n    </div>\n</div>\n",
  "response_html": "<!DOCTYPE html>\n\n<html>\n<head>\n    <meta charset=\"utf-8\">\n    <title>Manifestação de Interesse Recebida</title>\n</head>\n<body style=\"margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa;\">\n    \n    <!-- LÓGICA DE DADOS -->\n    {% set uel = frappe.get_doc(\"Definicao da UEL\") %}\n    {% set uel_name = uel.nome_da_uel or \"Sua UEL\" %}\n    {% set uel_type = uel.tipo_uel or \"Unidade\" %}\n    {% set whatsapp = uel.telefone %}\n    {% set dia = uel.dia_de_atividade or \"Sábado\" %}\n    {% set inicio = uel['horário_de_início'] %}\n    {% set termino = uel['horário_de_término'] %}\n\n    <!-- LOGICA JOVENS -->\n    {% set siblings = frappe.get_all(\"Resposta Manifestacao de Interesse\", filters={\"email_do_responsavel\": doc.email_do_responsavel}, fields=[\"nome_do_jovem\"]) %}\n    {% set names = [] %}\n    {% for s in siblings %}\n        {% if s.nome_do_jovem not in names %}\n            {% set _ = names.append(s.nome_do_jovem) %}\n        {% endif %}\n    {% endfor %}\n    {% if not names %}\n        {% if doc.nome_do_jovem %}\n           {% set _ = names.append(doc.nome_do_jovem) %}\n        {% endif %}\n    {% endif %}\n\n    <!-- LOGICA GENEROS -->\n    {% set is_male = uel_type == \"Grupo Escoteiro\" %}\n    {% set prep_do = 'do' if is_male else 'da' %}\n    {% set prep_no = 'no' if is_male else 'na' %}\n    {% set prep_pelo = 'pelo' if is_male else 'pela' %}\n    {% set prep_a = 'ao' if is_male else 'à' %}\n    \n    {% set is_sabado_domingo = dia in [\"Sábado\", \"Domingo\"] %}\n    {% set art_dia = 'Todos os' if is_sabado_domingo else 'Todas as' %}\n\n    <!-- Wrapper Cinza -->\n    <div style=\"background-color: #f8f9fa; padding: 40px 20px;\">\n        \n        <!-- Container Principal -->\n        <div style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.08);\">\n            \n            <!-- HEADER -->\n            <div style=\"background-color: #0d4d91; color: white; padding: 30px 30px; text-align: center;\">\n                 <h1 style=\"margin: 0; font-size: 24px; font-weight: 600;\">Bem-vindo(a) {{ prep_a }} {{ uel_type }} {{ uel_name }}!</h1>\n            </div>\n            \n            <!-- CONTEÚDO -->\n            <div style=\"padding: 40px 30px;\">\n                <h2 style=\"margin-top: 0; color: #1e293b; font-size: 20px; text-align: center; margin-bottom: 25px;\">Ficamos muito felizes com seu interesse!</h2>\n                \n                <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                    Olá <strong>{{ doc.nome_do_responsavel or 'Responsável' }}</strong>,\n                </p>\n                \n                <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                    Você está recebendo este e-mail porque preencheu a manifestação de interesse para {{ 'os jovens' if names|length > 1 else 'o(a) jovem' }}:\n                </p>\n\n                <ul style=\"color: #64748b; font-size: 16px; line-height: 1.6; padding-left: 20px; margin-top: 5px; margin-bottom: 20px;\">\n                    {% for name in names %}\n                        <li><strong>{{ name }}</strong></li>\n                    {% endfor %}\n                </ul>\n\n                <p style=\"color: #64748b; font-size: 16px; line-height: 1.6;\">\n                    Em breve, você receberá um <strong>segundo e-mail</strong> neste mesmo endereço para cadastrar sua senha de acesso ao <strong>Gris</strong>.\n                </p>\n\n                <!-- CARD O QUE É O GRIS -->\n                <div style=\"background-color: #f0f9ff; padding: 20px; margin: 30px 0; border-radius: 6px;\">\n                    <h3 style=\"margin-top: 0; color: #0c4a6e; font-size: 16px;\">O que é o Gris?</h3>\n                    <p style=\"color: #334155; font-size: 14px; line-height: 1.5; margin-bottom: 15px;\">\n                        O Gris é o sistema interno de gestão {{ prep_do }} {{ uel_type }} {{ uel_name }}. Através dele, você poderá acompanhar cada etapa do processo de entrada.\n                    </p>\n                    <p style=\"color: #334155; font-size: 14px; line-height: 1.5; margin: 0;\">\n                        Algumas etapas do processo de recepção (como agendamento de visitas e envio de documentos) serão feitas diretamente pelo sistema.\n                    </p>\n                </div>\n\n                <!-- ALERTA REGISTRO -->\n                <div style=\"background-color: #fff3cd; border: 1px solid #ffeeba; border-radius: 6px; padding: 15px; margin: 25px 0; color: #856404; font-size: 14px; line-height: 1.5;\">\n                    <strong>Importante:</strong> O cadastro no Gris <span style=\"text-decoration: underline;\">não é o registro escoteiro oficial</span>. Ele é apenas nosso sistema de gestão interna para organizar a recepção.\n                </div>\n                \n                <!-- DIAGRAMA DE FLUXO -->\n                <h3 style=\"color: #1e293b; font-size: 18px; margin-top: 40px; text-align: center;\">Fluxo de Recepção</h3>\n                \n                <table style=\"width: 100%; table-layout: fixed; border-spacing: 0; margin-top: 20px;\">\n                    <tr>\n                        <td style=\"text-align: center; vertical-align: top; position: relative;\">\n                            <div style=\"width: 30px; height: 30px; background-color: #22c55e; border-radius: 50%; margin: 0 auto; line-height: 30px; color: white; font-weight: bold; position: relative; z-index: 2;\">✓</div>\n                         \n                            <div style=\"font-size: 12px; color: #0f172a; margin-top: 8px; font-weight: 600;\">Manifestação de Interesse</div>\n                        </td>\n                        <td style=\"text-align: center; vertical-align: top; position: relative;\">\n                            <div style=\"width: 30px; height: 30px; background-color: #cbd5e1; border-radius: 50%; margin: 0 auto; line-height: 30px; color: #64748b; font-weight: bold; position: relative; z-index: 2;\">2</div>\n                            \n                        \n                            <div style=\"font-size: 12px; color: #64748b; margin-top: 8px;\">Agendamento de Visita</div>\n                        </td>\n                        <td style=\"text-align: center; vertical-align: top; position: relative;\">\n                            <div style=\"width: 30px; height: 30px; background-color: #cbd5e1; border-radius: 50%; margin: 0 auto; line-height: 30px; color: #64748b; font-weight: bold; position: relative; z-index: 2;\">3</div>\n                          \n                            <div style=\"font-size: 12px; color: #64748b; margin-top: 8px;\">Visita ao Grupo</div>\n                        </td>\n                        <td style=\"text-align: center; vertical-align: top; position: relative;\">\n                            <div style=\"width: 30px; height: 30px; background-color: #cbd5e1; border-radius: 50%; margin: 0 auto; line-height: 30px; color: #64748b; font-weight: bold; position: relative; z-index: 2;\">4</div>\n          \n                            <div style=\"font-size: 12px; color: #64748b; margin-top: 8px;\">Acompanhamento e integração</div>\n                        </td>\n                    </tr>\n                </table>\n\n                <!-- INFO ATIVIDADES -->\n                <div style=\"margin-top: 40px; text-align: center;\">\n                    <h3 style=\"color: #1e293b; font-size: 16px; margin-bottom: 10px;\">Horário das Atividades</h3>\n                    <p style=\"color: #64748b; font-size: 15px; margin: 0;\">\n                        {{ art_dia }} <strong>{{ dia }}s</strong><br>\n                        das {{ inicio or '---' }} às {{ termino or '---' }}\n                    </p>\n                </div>\n                \n                <!-- CONTATO -->\n                <div style=\"margin-top: 40px; border-top: 1px solid #e2e8f0; paddingTop: 30px;\">\n                    <p style=\"color: #64748b; font-size: 14px; line-height: 1.6; text-align: center;\">\n                        Vamos entrar em contato pelo telefone <strong>{{ doc.celular_do_responsavel }}</strong> para agendar os próximos passos.\n                    </p>\n                    <p style=\"color: #64748b; font-size: 14px; line-height: 1.6; text-align: center;\">Ficou com dúvida? Fale com a gente:</p>\n                </div>\n                \n                <!-- BOTÃO WHATSAPP -->\n                {% if whatsapp %}\n                <div style=\"text-align: center; margin-top: 20px; margin-bottom: 30px;\">\n                    <a href=\"https://wa.me/{{ whatsapp | replace(' ', '') | replace('-', '') | replace('(', '') | replace(')', '') }}\" style=\"background-color: #25D366; color: white; padding: 12px 28px; text-decoration: none; border-radius: 50px; display: inline-block; font-weight: 600; font-size: 15px; box-shadow: 0 4px 6px -1px rgba(37, 211, 102, 0.3);\">\n                        Entre em contato por WhatsApp\n                    </a>\n                </div>\n                {% endif %}\n\n            </div>\n            \n            <!-- FOOTER -->\n            <div style=\"background-color: #f1f5f9; padding: 20px 20px; text-align: center; border-top: 1px solid #e2e8f0; color: #94a3b8; font-size: 12px; line-height: 1.5;\">\n                Enviado com amor ❤️ {{ prep_pelo }} {{ uel_type }} {{ uel_name }}<br>\n                Este é um e-mail automático, por favor não responda.\n            </div>\n        </div>\n    </div>\n</body>\n</html>",
  "subject": "Manifestação de Interesse Recebida",
  "use_html": 1
 }
]